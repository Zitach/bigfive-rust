{
  "build": {
    "beforeBuildCommand": "pnpm -C ../frontend build",
    "beforeDevCommand": "pnpm -C ../frontend dev --host",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "productName": "Big Five",
  "version": "0.1.0",
  "app": {
    "windows": [
      {
        "title": "Big Five",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "identifier": "com.bigfive.desktop",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
